<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Admin Users - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/drinks">Drinks</a>
        <a href="/admin/orders">Orders</a>
      </div>
      <div class="nav-right">
        <span class="user-info">👤 <%= user.username %></span>
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <h1>Manage Users</h1>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Balance</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) { %>
            <tr>
              <td><%= u.id %></td>
              <td><%= u.username %></td>
              <td><%= u.email %></td>
              <td><span class="badge <%= u.role === 'admin' ? 'badge-admin' : 'badge-user' %>"><%= u.role %></span></td>
              <td>$<%= u.balance %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
