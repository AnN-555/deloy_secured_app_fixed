<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Admin Orders - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/drinks">Drinks</a>
        <a href="/admin/orders">Orders</a>
      </div>
      <div class="nav-right">
        <span class="user-info">👤 <%= user.username %></span>
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <h1>Manage Orders</h1>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>User</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(o) { %>
            <tr>
              <td>#<%= o.id %></td>
              <td><%= o.username %></td>
              <td>$<%= o.total ? o.total.toFixed(2) : '0.00' %></td>
              <td><span class="badge badge-user"><%= o.status %></span></td>
              <td><%= o.order_date ? new Date(o.order_date).toLocaleDateString() : '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
