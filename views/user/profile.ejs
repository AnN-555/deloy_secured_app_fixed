<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Profile - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/user/cart">Cart</a>
        <a href="/user/orders">Orders</a>
        <a href="/user/reviews">Reviews</a>
      </div>
      <div class="nav-right">
        <span class="user-info">👤 <%= user.username %></span>
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <h1>My Profile</h1>

    <div class="card" style="max-width:500px;">
      <p style="margin-bottom:15px;"><strong>Username:</strong> <%= user.username %></p>
      <p style="margin-bottom:15px;"><strong>Email:</strong> <%= user.email %></p>
      <p style="margin-bottom:15px;"><strong>Role:</strong> <span class="badge <%= user.role === 'admin' ? 'badge-admin' : 'badge-user' %>"><%= user.role %></span></p>
      <p style="margin-bottom:15px;"><strong>Balance:</strong> <span style="color:var(--success);font-size:20px;">$<%= user.balance %></span></p>
    </div>
  </div>
</body>
</html>
