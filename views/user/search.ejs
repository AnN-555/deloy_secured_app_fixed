<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Search - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/user/cart">Cart</a>
        <a href="/user/orders">Orders</a>
      </div>
      <div class="nav-right">
        <span class="user-info">👤 <%= user.username %></span>
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <h1>Search Drinks</h1>

    <form action="/user/search" method="POST" style="margin-bottom:20px;">
      <input type="text" name="q" placeholder="Search drinks..." value="<%= query %>" required style="padding:12px;width:300px;background:var(--bg-input);border:1px solid var(--border);border-radius:8px;color:var(--text);">
      <button type="submit" class="btn">Search</button>
      <a href="/user/menu" class="btn" style="background:var(--accent);">View All</a>
    </form>

    <div class="drinks-grid">
      <% if (drinks && drinks.length > 0) { %>
        <% drinks.forEach(function(drink) { %>
          <div class="drink-card">
            <div style="font-size:48px;"><%= drink.image %></div>
            <h3><%= drink.name %></h3>
            <p class="price">$<%= drink.price.toFixed(2) %></p>
          </div>
        <% }); %>
      <% } else { %>
        <p style="color:var(--text-muted);">No drinks found.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
